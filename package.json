{
  "name": "@inc2734/unitone-css",
  "version": "0.97.0",
  "description": "",
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.2.3"
  },
  "volta": {
		"node": "24.14.1"
  },
  "exports": {
    "./app": "./dist/app.js",
    "./library": "./dist/library.js",
    "./layout-primitives": "./dist/layout-primitives/index.js",
    "./layout-primitives/*/react": "./dist/layout-primitives/*/react.js",
    "./layout-primitives/*/behavior": "./dist/layout-primitives/*/behavior.js",
    "./behaviors": "./dist/behaviors/index.js",
    "./behaviors/*": "./dist/behaviors/*.js",
    "./compatibility": "./dist/compatibility/index.js",
    "./compatibility/*": "./dist/compatibility/*.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inc2734/unitone-css"
  },
  "files": [
    "src",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "css"
  ],
  "scripts": {
    "prepublish": "run-s build",
    "clean": "rimraf dist",
    "css:app": "sass --no-source-map src/app.scss:dist/app.css && postcss dist/app.css -r",
    "css": "run-p css:*",
    "js": "rollup -c --bundleConfigAsCjs",
    "build": "run-s clean format css js",
    "docs:start": "npm run dev -w website",
    "docs:build": "npm run build -w website",
    "mcp:check": "npm run check -w @inc2734/unitone-css-mcp",
    "skills:install": "node packages/skills/bin/skillpack-install.mjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "format:js": "prettier --write './src/**/*.{js,jsx}'",
    "format": "run-p format:*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "cssnano": "^7.1.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "sass": "^1.99.0"
  },
  "workspaces": [
    "website",
    "packages/mcp"
  ]
}
